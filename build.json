{
  "buildSteps": [
    {
      "type": "copy",
      "source": "assets",
      "target": "assets",
      "override": true
    },
    {
      "_comment": "ROOT INDEX \u2014 language detection redirect, generated once",
      "type": "resolve",
      "template": "partials/prepare-index.html",
      "target": "current"
    },
    {
      "type": "resolve",
      "template": "index.html",
      "target": "pages.index"
    },
    {
      "type": "output",
      "source": "pages.index",
      "target": "index.html",
      "override": true
    },
    {
      "_comment": "404 PAGE \u2014 redirect for unknown URLs",
      "type": "resolve",
      "template": "partials/prepare-404.html",
      "target": "current"
    },
    {
      "type": "resolve",
      "template": "404.html",
      "target": "pages.404"
    },
    {
      "type": "output",
      "source": "pages.404",
      "target": "404.html",
      "override": true
    },
    {
      "type": "loop",
      "collection": [
        {
          "lang": "en"
        },
        {
          "lang": "ro"
        }
      ],
      "as": "langItem",
      "parallel": false,
      "steps": [
        {
          "_comment": "Resolve shared partials \u2014 these read ctx.commons which is always seeded",
          "type": "resolve",
          "template": "partials/prepare-shared.html",
          "target": "current"
        },
        {
          "_comment": "HOME",
          "type": "resolve",
          "template": "partials/prepare-home.html",
          "target": "current"
        },
        {
          "type": "resolve",
          "template": "partials/html-open.html",
          "target": "partials.htmlOpen"
        },
        {
          "type": "resolve",
          "template": "partials/site-header.html",
          "target": "partials.siteHeader"
        },
        {
          "type": "resolve",
          "template": "partials/site-footer.html",
          "target": "partials.siteFooter"
        },
        {
          "type": "resolve",
          "template": "home.html",
          "target": "pages.home"
        },
        {
          "type": "output",
          "source": "pages.home",
          "target": "{{fn:utils.pageOutPath(home,{{langItem.lang}})}}",
          "override": true
        },
        {
          "_comment": "DIRECTORY",
          "type": "resolve",
          "template": "partials/prepare-directory.html",
          "target": "current"
        },
        {
          "type": "resolve",
          "template": "partials/html-open.html",
          "target": "partials.htmlOpen"
        },
        {
          "type": "resolve",
          "template": "partials/site-header.html",
          "target": "partials.siteHeader"
        },
        {
          "type": "resolve",
          "template": "partials/site-footer.html",
          "target": "partials.siteFooter"
        },
        {
          "type": "resolve",
          "template": "directory.html",
          "target": "pages.directory"
        },
        {
          "type": "output",
          "source": "pages.directory",
          "target": "{{fn:utils.pageOutPath(portfolio/music/directory,{{langItem.lang}})}}",
          "override": true
        },
        {
          "_comment": "CONTACT",
          "type": "resolve",
          "template": "partials/prepare-contact.html",
          "target": "current"
        },
        {
          "type": "resolve",
          "template": "partials/html-open.html",
          "target": "partials.htmlOpen"
        },
        {
          "type": "resolve",
          "template": "partials/site-header.html",
          "target": "partials.siteHeader"
        },
        {
          "type": "resolve",
          "template": "partials/site-footer.html",
          "target": "partials.siteFooter"
        },
        {
          "type": "resolve",
          "template": "contact.html",
          "target": "pages.contact"
        },
        {
          "type": "output",
          "source": "pages.contact",
          "target": "{{fn:utils.pageOutPath(contact,{{langItem.lang}})}}",
          "override": true
        },
        {
          "_comment": "PIECE PAGES",
          "type": "loop",
          "collection": "{{fn:utils.loadPieces(contents/pieces)}}",
          "as": "piece",
          "parallel": false,
          "steps": [
            {
              "type": "resolve",
              "template": "partials/prepare-piece.html",
              "target": "current"
            },
            {
              "type": "resolve",
              "template": "partials/html-open.html",
              "target": "partials.htmlOpen"
            },
            {
              "type": "resolve",
              "template": "partials/site-header.html",
              "target": "partials.siteHeader"
            },
            {
              "type": "resolve",
              "template": "partials/site-footer.html",
              "target": "partials.siteFooter"
            },
            {
              "type": "resolve",
              "template": "piece.html",
              "target": "pages.piece"
            },
            {
              "type": "output",
              "source": "pages.piece",
              "target": "{{fn:utils.pieceOutPath({{piece.slug}},{{langItem.lang}})}}",
              "override": true
            }
          ]
        }
      ]
    }
  ],
  "before": [],
  "after": []
}